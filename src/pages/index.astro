  <script>
    // Custom cursor
    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
    function animCursor() {
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
      rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(animCursor);
    }
    animCursor();

    // Wave canvas
    const canvas = document.getElementById('wave-canvas');
    const ctx = canvas.getContext('2d');
    let t = 0;
    function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const waves = [
        { a: 42, f: 0.007, s: 0.009, y: 0.52, c: 'rgba(27,58,92,0.55)', w: 1.5 },
        { a: 30, f: 0.011, s: 0.014, y: 0.60, c: 'rgba(74,158,187,0.28)', w: 1   },
        { a: 55, f: 0.005, s: 0.007, y: 0.70, c: 'rgba(27,58,92,0.38)', w: 2   },
        { a: 20, f: 0.016, s: 0.020, y: 0.42, c: 'rgba(127,168,212,0.15)', w: 0.8 },
        { a: 35, f: 0.009, s: 0.011, y: 0.80, c: 'rgba(30,77,122,0.25)', w: 1.2 },
      ];
      waves.forEach(w => {
        ctx.beginPath(); ctx.strokeStyle = w.c; ctx.lineWidth = w.w;
        for (let x = 0; x <= canvas.width; x += 2) {
          const y = canvas.height * w.y + Math.sin(x * w.f + t * w.s * 60) * w.a;
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      });
      t += 0.016;
      requestAnimationFrame(draw);
    }
    resize(); window.addEventListener('resize', resize); draw();

    // Fade-in on scroll
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Active nav link
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-links a');
    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(s => { if (window.scrollY >= s.offsetTop - 200) current = s.id; });
      navLinks.forEach(a => {
        a.style.color = a.getAttribute('href') === '#' + current ? 'var(--text1)' : '';
      });
    });
  </script>
